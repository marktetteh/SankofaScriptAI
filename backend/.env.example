# ── SankofahScriptAI environment variables ──────────────────────────────────
# Copy this file to .env and fill in your values.

# Google AI Studio key — get one free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/sankofascript
# Render:  postgresql://user:pass@host/dbname?sslmode=require
# Neon:    postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/sankofascript

# Optional overrides
# GOOGLE_MODEL=gemma-4-31b-it
# PORT=8000
